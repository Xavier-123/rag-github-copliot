# =============================================================================
# Agentic RAG + Self-Improving RAG – Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables use the RAG_ prefix.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider  (choose ONE)
# -----------------------------------------------------------------------------

# Option A: OpenAI
RAG_OPENAI_API_KEY=sk-...
RAG_OPENAI_MODEL=gpt-4o-mini
RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Option B: Azure OpenAI (overrides OpenAI if set)
# RAG_AZURE_OPENAI_API_KEY=...
# RAG_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# RAG_AZURE_OPENAI_API_VERSION=2024-02-01
# RAG_AZURE_OPENAI_DEPLOYMENT=gpt-4o
# RAG_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Provider selector
RAG_LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# Retrieval Backends
# -----------------------------------------------------------------------------

# Default retrieval strategy: vector | graph | web | hybrid
RAG_DEFAULT_RETRIEVAL_MODE=hybrid
RAG_RETRIEVAL_TOP_K=10
RAG_RERANK_TOP_K=5

# Vector store: chroma | faiss | milvus | weaviate
RAG_VECTOR_STORE_TYPE=chroma
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8000
RAG_CHROMA_COLLECTION=rag_knowledge

# FAISS (local, no server required)
# RAG_FAISS_INDEX_PATH=./data/faiss_index

# Milvus
# RAG_MILVUS_URI=http://localhost:19530

# Weaviate
# RAG_WEAVIATE_URL=http://localhost:8080

# GraphRAG – Neo4j
# RAG_NEO4J_URI=bolt://localhost:7687
# RAG_NEO4J_USERNAME=neo4j
# RAG_NEO4J_PASSWORD=your_neo4j_password

# -----------------------------------------------------------------------------
# Web Search
# -----------------------------------------------------------------------------

# Provider: serper | tavily | bing
RAG_WEB_SEARCH_PROVIDER=serper
# RAG_SERPER_API_KEY=...
# RAG_TAVILY_API_KEY=...
# RAG_BING_SEARCH_API_KEY=...

# -----------------------------------------------------------------------------
# Memory
# -----------------------------------------------------------------------------

RAG_REDIS_URL=redis://localhost:6379
RAG_CONVERSATION_WINDOW=10
RAG_EPISODIC_MEMORY_MAX_ENTRIES=1000

# -----------------------------------------------------------------------------
# Evaluation & Self-Improvement
# -----------------------------------------------------------------------------

RAG_EVALUATION_ENABLED=true
# Evaluation framework: ragas | llm_judge | dspy
RAG_EVALUATION_FRAMEWORK=llm_judge
RAG_FEEDBACK_LEARNING_ENABLED=true
RAG_OPTIMIZATION_CYCLE_TURNS=50
# Score below which a retrieval strategy is considered poor (FeedbackLearning)
RAG_FEEDBACK_POOR_SCORE_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Pipeline
# -----------------------------------------------------------------------------

RAG_MAX_REASONING_ITERATIONS=5
# Minimum confidence score before reflection agent triggers a retry
RAG_CONFIDENCE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

RAG_LOG_LEVEL=INFO
