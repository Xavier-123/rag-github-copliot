# ============================================================
# 企业级 RAG 对话系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── LLM 配置 ─────────────────────────────────────────────────
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=your_openai_api_key_here
# LLM_API_BASE=https://api.openai.com/v1  # 自定义 API Base（可选）
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ── 嵌入模型配置 ──────────────────────────────────────────────
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ── 向量数据库配置 ────────────────────────────────────────────
VECTOR_STORE_PERSIST_DIR=./data/chroma_db
VECTOR_STORE_COLLECTION_NAME=rag_documents
VECTOR_STORE_TOP_K=10
VECTOR_STORE_SIMILARITY_THRESHOLD=0.7

# ── GraphRAG 配置 ─────────────────────────────────────────────
GRAPH_RAG_ENABLED=false
GRAPH_RAG_WORKSPACE_DIR=./data/graphrag
GRAPH_RAG_TOP_K=5

# ── Web 搜索配置 ──────────────────────────────────────────────
WEB_SEARCH_ENABLED=true
WEB_SEARCH_ENGINE=duckduckgo
WEB_SEARCH_MAX_RESULTS=5

# ── 重排序配置 ────────────────────────────────────────────────
RERANK_METHOD=cross_encoder
RERANK_TOP_K=5

# ── 记忆系统配置 ──────────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_MAX_HISTORY=20
MEMORY_SUMMARY_THRESHOLD=10

# ── 评估配置 ──────────────────────────────────────────────────
EVAL_ENABLED=false  # 开发环境建议关闭，节省 API 调用
EVAL_FEEDBACK_THRESHOLD=0.7

# ── 系统配置 ──────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RETRIES=3
ENABLE_TRACING=false
# LANGSMITH_API_KEY=your_langsmith_key  # LangSmith 追踪（可选）
